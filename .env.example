# --- OpenRouter ---
# Comma-separated list of OpenRouter API keys. The key pool rotates across these.
OPENROUTER_KEYS=sk-or-key1,sk-or-key2,sk-or-key3
# Base URL for the OpenRouter API (override for testing/mocking).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model used when a request does not specify one.
DEFAULT_MODEL=openai/gpt-4o-mini
# Cheaper model used for summarization calls.
SUMMARY_MODEL=openai/gpt-4o-mini

# --- Shared infra (YARA postgres/redis — see ../infra/.env.example) ---
# Host-local URLs for `npm run dev` / `npm run db:migrate` (infra published ports).
DATABASE_URL=postgres://yara:yara_secret_password@localhost:5434/yara_ai
REDIS_URL=redis://:yara_redis_password@localhost:6380
# Used by docker-compose.yml to build in-network URLs (must match ../infra/.env).
POSTGRES_USER=yara
POSTGRES_PASSWORD=yara_secret_password
AI_DATABASE_NAME=yara_ai
REDIS_PASSWORD=yara_redis_password

# --- Auth ---
# Symmetric secret for verifying end-user JWTs (HS256). For RS256/asymmetric,
# set JWT_PUBLIC_KEY instead and JWT_ALG=RS256.
JWT_SECRET=dev-super-secret-change-me
JWT_ALG=HS256
# Optional: PEM public key for asymmetric verification (overrides JWT_SECRET when set).
# JWT_PUBLIC_KEY=
# Claim that carries the user id (default: sub).
JWT_USER_CLAIM=sub

# --- Limits ---
# Per-user request rate limit (requests per minute).
RATE_LIMIT_RPM=60
# Per-user token budget per period.
USER_TOKEN_BUDGET=200000
# Budget period: "day" or "month".
BUDGET_PERIOD=day
# Summarize once a chat's recent (un-summarized) window exceeds this many messages.
SUMMARIZE_AFTER_MESSAGES=20
# How many recent messages to keep verbatim after summarizing.
KEEP_RECENT_MESSAGES=10

# --- Cache / locks ---
# Per-chat history cache TTL in seconds.
CACHE_TTL_SECONDS=300
# Per-chat lock TTL in milliseconds (auto-released safety net).
CHAT_LOCK_TTL_MS=120000

# --- Server ---
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
